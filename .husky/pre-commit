#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# 1. Run lint-staged to check only staged files
echo "1. Linting staged files..."
pnpm lint-staged || {
  echo "❌ Linting failed. Fix the errors before committing."
  exit 1
}

# 2. Run unit tests
echo "2. Running unit tests..."
pnpm test:unit || {
  echo "❌ Unit tests failed. Fix the tests before committing."
  exit 1
}

# 3. Type checking
echo "3. Running TypeScript type check..."
pnpm build || {
  echo "❌ TypeScript type checking failed. Fix the errors before committing."
  exit 1
}

echo "✅ All pre-commit checks passed!"
