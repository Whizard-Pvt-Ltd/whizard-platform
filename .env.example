# Whizard Platform - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Database Configuration
# ============================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/whizard"

# ============================================
# Stack Auth Configuration
# ============================================
# Get these from https://app.stack-auth.com/projects
STACK_AUTH_PROJECT_ID="a3f5b8a7-22d3-49d5-9f56-76e0489e8d51"
STACK_AUTH_PUBLISHABLE_CLIENT_KEY="pck_emn3m14ezqavtsp7b0bbv91swt0cpkazqy9ax83pfcmp8"
STACK_AUTH_SECRET_SERVER_KEY="ssk_bjnjrd1szrzvy3mrs308bphmg5teh4ebc54gz2cgxfn1r"

# Vite-compatible environment variables (for Angular frontend)
VITE_STACK_AUTH_PROJECT_ID="a3f5b8a7-22d3-49d5-9f56-76e0489e8d51"
VITE_STACK_AUTH_PUBLISHABLE_CLIENT_KEY="pck_emn3m14ezqavtsp7b0bbv91swt0cpkazqy9ax83pfcmp8"

# Stack Auth User Sync Configuration
STACK_AUTH_DEFAULT_TENANT_TYPE="SYSTEM"
STACK_AUTH_DEFAULT_TENANT_ID="system"
STACK_AUTH_MFA_REQUIRED="false"

# ============================================
# Server Ports
# ============================================
BFF_PORT=3000
CORE_API_PORT=3001
ANGULAR_PORT=4200

# ============================================
# Node Environment & Logging Configuration
# ============================================
NODE_ENV="development"
LOG_LEVEL="info"

# ============================================
# Kafka Configuration (Optional - for later)
# ============================================
# KAFKA_BROKERS="localhost:9092"
# KAFKA_CLIENT_ID="whizard-iam"
# KAFKA_GROUP_ID="whizard-iam-group"

# ============================================
# Auth0 Configuration (Optional - for SSO)
# ============================================
# AUTH0_DOMAIN="your-tenant.auth0.com"
# AUTH0_CLIENT_ID="your-client-id"
# AUTH0_CLIENT_SECRET="your-client-secret"
# AUTH0_AUDIENCE="https://api.whizard.com"
# AUTH0_CALLBACK_URL="http://localhost:3000/auth/callback/auth0"
