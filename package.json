{
  "name": "whizard-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.0",
  "pnpm": {
    "overrides": {
      "typescript": "5.8.2",
      "prisma": "6.19.2",
      "@prisma/client": "6.19.2"
    }
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "prisma generate && husky install",
    "build": "tsc -p tsconfig.base.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "ai:check-notes": "tools/scripts/check-ai-notes.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run -c vitest.config.unit.ts",
    "test:integration": "vitest run -c vitest.config.integration.ts",
    "test:contract": "vitest run -c vitest.config.contract.ts",
    "test:e2e": "vitest run -c vitest.config.e2e.ts",
    "test:all": "pnpm test:unit && pnpm test:integration && pnpm test:contract",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:reset": "prisma migrate reset",
    "start:web-admin": "ng serve admin-portal",
    "build:web-admin": "ng build admin-portal",
    "bootstrap": "bash tools/scripts/bootstrap.sh",
    "verify:env": "bash tools/scripts/verify-env.sh",
    "db:setup": "bash tools/scripts/db-setup.sh",
    "build:iam": "bash tools/scripts/build-iam.sh",
    "dev:all": "bash tools/scripts/dev-all.sh",
    "dev:bff": "tsx watch apps/api/bff/src/server.ts",
    "dev:core-api": "tsx watch apps/api/core-api/src/server.ts",
    "build:bff": "nx build bff",
    "build:core-api": "nx build core-api",
    "build:all": "nx run-many --target=build --all",
    "start:bff": "node apps/api/bff/dist/server.js",
    "start:core-api": "node apps/api/core-api/dist/server.js",
    "clean": "find . -name 'dist' -type d -prune -exec rm -rf {} + && find . -name 'node_modules' -type d -prune -exec rm -rf {} + && find . -name '*.tsbuildinfo' -type f -delete && rm -rf .nx",
    "clean:dist": "find . -name 'dist' -type d -prune -exec rm -rf {} + && find . -name '*.tsbuildinfo' -type f -delete && rm -rf .nx",
    "clean:modules": "find . -name 'node_modules' -type d -prune -exec rm -rf {} +",
    "setup": "pnpm install --frozen-lockfile && pnpm build:all",
    "fresh": "pnpm clean && pnpm install && pnpm build:all",
    "fresh:quick": "pnpm clean:dist && pnpm build:all",
    "docker:build": "rm -rf apps/api/bff/dist apps/api/core-api/dist && docker compose build bff core-api",
    "docker:build:nocache": "rm -rf apps/api/bff/dist apps/api/core-api/dist && docker compose build --no-cache bff core-api",
    "docker:up": "docker compose up -d postgres && pnpm prisma:migrate:deploy && docker compose up bff core-api",
    "docker:up:d": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:logs:bff": "docker compose logs -f bff",
    "docker:logs:core-api": "docker compose logs -f core-api",
    "validate": "pnpm lint && pnpm test && pnpm build:all",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.0",
    "@angular/cli": "^19.2.0",
    "@angular/compiler-cli": "^19.2.0",
    "@nx/vite": "^22.5.4",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "esbuild": "^0.24.2",
    "eslint": "^9.22.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "nx": "^22.5.4",
    "only-allow": "^1.2.1",
    "prisma": "^6.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "5.8.2",
    "vite": "^6.0.0",
    "vitest": "^3.0.8"
  },
  "dependencies": {
    "@angular/animations": "^19.2.0",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@playwright/test": "^1.58.2",
    "@prisma/client": "^6.4.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "rxjs": "^7.8.1",
    "zone.js": "^0.15.0"
  }
}
