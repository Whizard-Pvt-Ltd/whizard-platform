{
  "name": "whizard-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.0",
  "pnpm": {
    "overrides": {
      "typescript": "5.8.2"
    }
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "prisma generate",
    "build": "tsc -p tsconfig.base.json --noEmit",
    "lint": "eslint .",
    "ai:check-notes": "tools/scripts/check-ai-notes.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --dir libs",
    "test:integration": "vitest run --dir tests/contract",
    "test:e2e": "vitest run --dir tests/e2e",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:reset": "prisma migrate reset",
    "start:web-admin": "ng serve admin-portal",
    "build:web-admin": "ng build admin-portal",
    "bootstrap": "bash tools/scripts/bootstrap.sh",
    "verify:env": "bash tools/scripts/verify-env.sh",
    "db:setup": "bash tools/scripts/db-setup.sh",
    "build:iam": "bash tools/scripts/build-iam.sh",
    "dev:all": "bash tools/scripts/dev-all.sh",
    "dev:bff": "pnpm tsx apps/api/bff/src/server.ts",
    "dev:core-api": "pnpm tsx apps/api/core-api/src/server.ts"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^9.22.0",
    "only-allow": "^1.2.1",
    "prisma": "^6.4.1",
    "typescript": "5.8.2",
    "vitest": "^3.0.8",
    "@angular-devkit/build-angular": "^19.2.0",
    "@angular/cli": "^19.2.0",
    "@angular/compiler-cli": "^19.2.0",
    "tsx": "^4.19.2",
    "ts-node": "^10.9.2",
    "@types/bcrypt": "^5.0.2"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "@angular/animations": "^19.2.0",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/router": "^19.2.0",
    "rxjs": "^7.8.1",
    "zone.js": "^0.15.0",
    "fastify": "^5.3.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^12.0.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "bcrypt": "^5.1.1"
  }
}
